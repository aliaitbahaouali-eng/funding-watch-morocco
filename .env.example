# ============================================
# Funding Watch Morocco - Environment variables
# ============================================
# Copy this file to `.env.local` and fill the values.
# NEVER commit `.env.local` or the service role key.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Server-side only — used by API routes and the Python scrapers.
# Must NEVER be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Email (Brevo / SendGrid) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=alerts@fundingwatch.ma
BREVO_SENDER_NAME=Funding Watch Morocco

# --- Cron / Webhook protection ---
# Random string used to authenticate the /api/cron and /api/ingest endpoints.
CRON_SECRET=change-me-to-a-long-random-string

# --- IA (Claude API — optionnel) ---
# Sans clé, lib/ai.js utilise les heuristiques locales.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- WhatsApp Business (Meta Cloud API — optionnel, Sprint 3c) ---
# Sans clés, /api/cron/whatsapp-alerts log les messages en mode 'simulated'.
# Requiert un template approuvé "funding_watch_high_match" dans Meta Business
# Manager (5 paramètres : nom orga, score %, titre opp, bailleur, deadline).
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=

# --- Brevo webhook secret (Sprint 2B.3 — tracking opens/clicks) ---
# Génère une chaîne aléatoire longue, puis configure le webhook Brevo :
#   Dashboard Brevo → Settings → Transactional → Webhooks
#   URL = https://funding-watch-morocco.vercel.app/api/webhooks/brevo?secret=<BREVO_WEBHOOK_SECRET>
#   Cocher TOUS les events : sent, delivered, opened, click, hard_bounce,
#   soft_bounce, spam, unsubscribed, deferred, blocked, invalid_email
BREVO_WEBHOOK_SECRET=

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Funding Watch Morocco
